<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
<title>Planet Toyota – Quotation Manager</title>
<meta name="description" content="Digital Quotation System for Planet Toyota, Narnaul" />
<meta name="theme-color" content="#EB0A1E" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black" />
<meta name="apple-mobile-web-app-title" content="PT Quotes" />
<link rel="manifest" href="manifest.json" />
<link rel="apple-touch-icon" href="icons/icon-192.png" />
<link rel="stylesheet" href="css/app.css" />
</head>
<body>
<div id="app">
  <!-- Login Screen -->
  <div id="screen-login" class="screen active">
    <div class="login-wrap">
      <div class="login-logo">
        <div class="logo-box">
          <span class="logo-t">T</span>
        </div>
        <div class="login-brand">PLANET TOYOTA</div>
        <div class="login-sub">Quotation Manager · Narnaul</div>
      </div>
      <div class="login-card">
        <div class="login-title">Select Your Name</div>
        <select id="exec-select" class="field-input">
          <option value="">— Select Executive —</option>
        </select>
        <div class="login-title" style="margin-top:18px">Enter PIN</div>
        <div class="pin-dots" id="pin-dots">
          <span></span><span></span><span></span><span></span>
        </div>
        <div class="pin-pad" id="pin-pad"></div>
        <div class="login-error" id="login-error"></div>
      </div>
      <div class="login-manager-link" onclick="showManagerLogin()">Manager Login →</div>
    </div>
  </div>

  <!-- Home Screen -->
  <div id="screen-home" class="screen">
    <div class="topbar">
      <div class="topbar-left">
        <div class="topbar-title">PT Quotes</div>
        <div class="topbar-sub" id="home-exec-name"></div>
      </div>
      <div class="topbar-right">
        <button class="icon-btn" onclick="logout()" title="Logout">⎋</button>
      </div>
    </div>
    <div class="screen-body">
      <div class="hero-card">
        <div class="hero-greeting" id="hero-greeting">Good morning</div>
        <div class="hero-name" id="hero-name">Executive</div>
        <div class="hero-stats" id="hero-stats">
          <div class="hstat"><div class="hstat-v" id="hs-total">0</div><div class="hstat-l">My Quotes</div></div>
          <div class="hstat-div"></div>
          <div class="hstat"><div class="hstat-v" id="hs-month">0</div><div class="hstat-l">This Month</div></div>
          <div class="hstat-div"></div>
          <div class="hstat"><div class="hstat-v" id="hs-value">₹0</div><div class="hstat-l">Pipeline</div></div>
        </div>
      </div>
      <button class="new-quote-btn" onclick="goTo('form')">+ New Quotation</button>
      <div class="section-label">RECENT QUOTES</div>
      <div class="search-wrap">
        <input type="search" id="home-search" class="search-input" placeholder="Search customer, model, phone..." oninput="renderHomeQuotes()" />
      </div>
      <div id="home-quote-list"></div>
    </div>
  </div>

  <!-- Form Screen -->
  <div id="screen-form" class="screen">
    <div class="topbar">
      <button class="back-btn" onclick="goTo('home')">‹</button>
      <div class="topbar-title">New Quotation</div>
      <div style="width:36px"></div>
    </div>
    <div class="screen-body" id="form-body">
      <!-- injected by JS -->
    </div>
  </div>

  <!-- Preview Screen -->
  <div id="screen-preview" class="screen">
    <div class="topbar no-print">
      <button class="back-btn" onclick="goTo('home')">‹</button>
      <div class="topbar-title" id="preview-title">Quotation</div>
      <button class="icon-btn red" onclick="goTo('form')" title="New">+</button>
    </div>
    <div class="screen-body" id="preview-body"></div>
  </div>

  <!-- Manager Screen -->
  <div id="screen-manager" class="screen">
    <div class="topbar">
      <button class="back-btn" onclick="logout()">‹</button>
      <div class="topbar-title">Manager Dashboard</div>
      <div style="width:36px"></div>
    </div>
    <div class="screen-body" id="manager-body"></div>
  </div>
</div>

<!-- Sync Toast -->
<div id="sync-toast" class="sync-toast"></div>

<script src="js/data.js"></script>
<script src="js/app.js"></script>
<script>
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', () => {
      navigator.serviceWorker.register('sw.js').catch(() => {});
    });
  }
</script>
</body>
</html>
